{
  "compilerOptions": {
    // === إعداداتك الحالية ===
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": "src",
    "outDir": "dist",
    "target": "ES2022",
    "sourceMap": true,
    "noImplicitAny": true,

  
    "jsx": "react-jsx",         
    "jsxImportSource": "react",
    "strict": true,             
    "esModuleInterop": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"] 
  },

  "include": ["src/**/*"],       
  "exclude": ["node_modules"]
}
